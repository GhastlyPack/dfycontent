# Customer.io Track API (server-side only)
# Get these from Customer.io: Settings -> Account Settings -> API Credentials -> Track API Keys
CUSTOMERIO_SITE_ID=
CUSTOMERIO_TRACK_API_KEY=
# 'us' (default) or 'eu' depending on your Customer.io workspace region
CUSTOMERIO_REGION=us

# Calendly inline embed (public, exposed to browser)
# Format: https://calendly.com/<your-handle>/<event-slug>
NEXT_PUBLIC_CALENDLY_URL=
